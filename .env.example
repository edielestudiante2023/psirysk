#--------------------------------------------------------------------
# PsyRisk - Variables de Entorno
#--------------------------------------------------------------------
# Copiar este archivo como .env y completar con valores reales.
# NUNCA commitear el archivo .env con credenciales.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app_baseURL = http://localhost/psyrisk/
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE (Principal)
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = psyrisk
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# Generar con: php spark key:generate
# Formato: hex2bin:<64 caracteres hex>

encryption.key =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# logger.threshold = 4

#--------------------------------------------------------------------
# EMAIL / SENDGRID
#--------------------------------------------------------------------
# Configuracion de SendGrid para email transaccional.
# Obtener API Key en: https://app.sendgrid.com/settings/api_keys

email.fromEmail = ''
email.fromName = 'PsyRisk - Cycloid Talent'
email.SMTPHost = 'smtp.sendgrid.net'
email.SMTPUser = 'apikey'
email.SMTPPass = ''
email.SMTPPort = 587
email.SMTPCrypto = 'tls'
email.protocol = 'smtp'
email.mailType = 'html'
email.charset = 'utf-8'
email.newline = "\r\n"

#--------------------------------------------------------------------
# DEBUG MODE
#--------------------------------------------------------------------
# Muestra SweetAlert con valores exactos de BD despues de guardar.
# Usar 'true' en desarrollo, 'false' en produccion.

DEBUG_SAVE_VERIFICATION = false

#--------------------------------------------------------------------
# OPENAI API
#--------------------------------------------------------------------
# API Key de OpenAI para generacion de interpretaciones IA.
# Obtener en: https://platform.openai.com/api-keys

OPENAI_API_KEY = ''
OPENAI_MODEL = 'gpt-4o'

#--------------------------------------------------------------------
# PRODUCCION (solo para scripts de migracion)
#--------------------------------------------------------------------
# No necesario para desarrollo local.

# PROD_DB_HOST =
# PROD_DB_PORT = 25060
# PROD_DB_NAME = psyrisk
# PROD_DB_USER =
# PROD_DB_PASS =
